# Database
DATABASE_URL=sqlite+aiosqlite:///data/reviewermatch.db
# Production: postgresql+asyncpg://user:pass@host:5432/reviewermatch

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=data/authors.faiss

# API auth
API_KEY=changeme
MAX_RESULTS=50

# OpenAlex
OPENALEX_EMAIL=your-email@example.com        # required for polite-pool access
OPENALEX_BASE_URL=https://api.openalex.org
OPENALEX_API_KEY=                            # optional: premium API key for higher rate limits

# Optional: Claude for explanation generation (falls back to heuristic if missing)
ANTHROPIC_API_KEY=

# Rate limiting (free tier)
FREE_TIER_DAILY_LIMIT=3

# --- Vercel only (api/match.js Edge proxy — not read by this FastAPI app)
# REVIEWERMATCH_API_URL=https://your-service.railway.app
# REVIEWERMATCH_API_KEY=<same value as API_KEY above>

# --- Railway only (set in Railway dashboard → Variables)
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/reviewermatch
# API_KEY=<your secure key — must match REVIEWERMATCH_API_KEY on Vercel>
# OPENALEX_EMAIL=your-email@example.com
# OPENALEX_API_KEY=<your OpenAlex premium key if you have one>
